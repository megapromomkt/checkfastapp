rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auxiliar: Verifica se o usuário logado é Admin com base na coleção de mapeamento agency_users
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/agency_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/agency_users/$(request.auth.uid)).data.role in [
          'Master Access', 'Admin', 'admin', 'RH', 'rh', 'Recursos Humanos', 
          'Financeiro', 'financeiro', 'Suporte', 'suporte', 'Trade', 'trade'
        ];
    }

    // Auxiliar: Verifica se o documento pertence ao próprio usuário (com base no ID ou authUid)
    function isOwner(userId, resource) {
      return request.auth != null && (
        request.auth.uid == userId || 
        (resource != null && resource.data.authUid == request.auth.uid)
      );
    }

    // Coleção Users: Dono ou Administradores podem ler/escrever.
    // Fallback: se o campo authUid não existir no documento (ainda não migrado), permitimos leitura/update pública para a migração
    match /users/{userId} {
      allow read: if (request.auth != null && (isOwner(userId, resource) || isAdmin())) 
                  || (resource == null 
                      || !('authUid' in resource.data) 
                      || resource.data.authUid == null 
                      || resource.data.authUid == ""
                      || resource.data.type == "prestador"
                      || resource.data.role == "worker"
                      || (resource.data.type != "interno" && resource.data.role != "admin"));
      
      allow create: if true; // Cadastro inicial
      
      allow update: if (request.auth != null && (isOwner(userId, resource) || isAdmin()))
                    || (resource != null 
                        && (!('authUid' in resource.data) 
                            || resource.data.authUid == null 
                            || resource.data.authUid == ""
                            || resource.data.type == "prestador"
                            || resource.data.role == "worker"
                            || (resource.data.type != "interno" && resource.data.role != "admin")));
      
      allow delete: if isAdmin();
    }

    // Coleções Operacionais (Clientes, Lojas, Projetos, etc): Leitura se logado, escrita para Admin
    match /clients/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /projects/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /stores/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /roles/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /payment_rules/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /demand_models/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /redes/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /bandeiras/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }

    // Demandas (Vagas): Prestadores leem vagas, apenas Admins criam/editam
    match /demands/{demandId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      allow update: if request.auth != null;
    }

    // Applications (Inscrições): Prestadores leem/gravam, Admins/RH gerenciam
    match /applications/{applicationId} {
      allow read, write: if request.auth != null;
    }

    // Support Chats (Chat): Prestadores leem/gravam, Admins/RH gerenciam todas
    match /support_chats/{promoterCpf} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Attendances (Check-ins): Prestadores leem e gravam apenas suas próprias presenças
    match /attendances/{attendanceId} {
      allow read, write: if request.auth != null && (
        resource.data.workerId == request.auth.uid || 
        request.resource.data.workerId == request.auth.uid ||
        ('email' in request.auth.token && (
          resource.data.workerCpf == request.auth.token.email.split('@')[0] ||
          request.resource.data.workerCpf == request.auth.token.email.split('@')[0]
        )) ||
        isAdmin()
      );
    }
    
    // EPI_deliveries: Leitura se logado, escrita para Admin
    match /epi_deliveries/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Regras para Usuários da Agência
    match /agency_users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId &&
        get(/databases/$(database)/documents/users/$(request.resource.data.cpf)).data.role in [
          'Master Access', 'Admin', 'admin', 'RH', 'rh', 'Recursos Humanos', 
          'Financeiro', 'financeiro', 'Suporte', 'suporte', 'Trade', 'trade'
        ] &&
        get(/databases/$(database)/documents/users/$(request.resource.data.cpf)).data.authUid == request.auth.uid;
    }
  }
}
